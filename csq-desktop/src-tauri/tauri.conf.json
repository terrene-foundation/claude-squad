{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Code Session Quota",
  "version": "0.1.0",
  "identifier": "foundation.terrene.claude-squad",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Code Session Quota",
        "width": 420,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src https://platform.claude.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:",
      "freezePrototype": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "appPosition": { "x": 160, "y": 200 },
        "applicationFolderPosition": { "x": 400, "y": 200 },
        "windowSize": { "width": 560, "height": 400 }
      }
    }
  }
}
